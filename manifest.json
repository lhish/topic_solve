{
  "manifest_version": 3,
  "name": "TabWake",
  "version": "0.3.1",
  "description": "让 linux.do 后台话题页的延迟阅读统计请求保持登录态。",
  "permissions": [
    "tabs",
    "webNavigation",
    "cookies",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://linux.do/*",
    "https://ping.ldstatic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
